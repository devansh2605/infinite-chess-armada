# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Database
BUGHOUSE_DB_USER=your_db_user
BUGHOUSE_DB_DATABASE=bughouse
BUGHOUSE_DB_PASSWORD=your_db_password
BUGHOUSE_DB_HOST=localhost
BUGHOUSE_DB_PORT=5432

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BUGHOUSE_TOKEN_SECRET=generate_a_strong_random_secret_here

# Server
BUGHOUSE_SERVER_PORT=3000
BUGHOUSE_LOG_FILE=./log.txt

# Email (optional — for password reset)
BUGHOUSE_EMAIL_ADDRESS=
BUGHOUSE_EMAIL_PASSWORD=

# Domain
BUGHOUSE_DOMAIN_NAME=localhost

# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Supabase — get from https://supabase.com/dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Frontend (public) Supabase keys — safe to expose in browser
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Backend URL for Socket.io client (empty = same origin in dev)
# In production: https://your-app.railway.app
REACT_APP_BACKEND_URL=

# Server
PORT=3000
BUGHOUSE_SERVER_PORT=3000
BUGHOUSE_LOG_FILE=./log.txt

# CORS — set to your Vercel URL in production
FRONTEND_URL=http://localhost:3000
